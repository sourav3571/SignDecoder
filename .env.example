# ════════════════════════════════════════════════════════════════════
# SignSpeak API Configuration Template
# Copy this to .env and fill in your values
# ════════════════════════════════════════════════════════════════════

# Application Settings
PROJECT_NAME=SignSpeak API
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Security (CHANGE IN PRODUCTION)
SECRET_KEY=your-super-secret-key-min-32-chars-change-this-in-production-12345
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# PostgreSQL Database
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=signspeak
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/signspeak

# MongoDB NoSQL Database
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=signspeak_db

# Redis Cache & Task Queue
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# Pinecone Vector Database (Phase 3)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-west4-gcp
PINECONE_INDEX_NAME=emoji-concepts
PINECONE_DIMENSION=384

# spaCy NLP Model
SPACY_MODEL=en_core_web_trf

# Sentence Transformers (SBERT)
SBERT_MODEL=all-MiniLM-L6-v2

# T5 Model for Gloss Generation
T5_MODEL_PATH=t5-small
T5_DEVICE=cpu

# Celery Task Queue (Phase 5)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# API Settings
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
API_V1_STR=/api/v1
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/signspeak.log

# AWS (for future deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
